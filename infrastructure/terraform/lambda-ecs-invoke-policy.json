{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "ecs:RunTask",
        "ecs:DescribeTasks",
        "ecs:StopTask"
      ],
      "Resource": "*"
    },
    {
      "Effect": "Allow",
      "Action": [
        "iam:PassRole"
      ],
      "Resource": [
        "arn:aws:iam::442426872653:role/foretale-dev-ecs-task-execution-role",
        "arn:aws:iam::442426872653:role/foretale-dev-ecs-task-role"
      ]
    }
  ]
}

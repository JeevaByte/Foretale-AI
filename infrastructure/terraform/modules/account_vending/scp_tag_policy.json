{
  "tags": {
    "Environment": {
      "tag_key": {
        "@@assign": "Environment"
      },
      "enforced_for": {
        "@@assign": ["ec2:instance", "s3:bucket", "lambda:function", "rds:db"]
      },
      "tag_value": {
        "@@assign": ["dev", "uat", "prod"]
      }
    },
    "CostCenter": {
      "tag_key": {
        "@@assign": "CostCenter"
      },
      "enforced_for": {
        "@@assign": ["ec2:instance", "s3:bucket", "lambda:function", "rds:db"]
      }
    },
    "Application": {
      "tag_key": {
        "@@assign": "Application"
      },
      "tag_value": {
        "@@assign": ["foretale-app"]
      },
      "enforced_for": {
        "@@assign": ["ec2:instance", "s3:bucket", "lambda:function"]
      }
    },
    "Owner": {
      "tag_key": {
        "@@assign": "Owner"
      },
      "enforced_for": {
        "@@assign": ["ec2:instance", "s3:bucket", "lambda:function", "rds:db"]
      }
    },
    "Sustainability": {
      "tag_key": {
        "@@assign": "Sustainability"
      },
      "enforced_for": {
        "@@assign": ["ec2:instance", "rds:db"]
      },
      "tag_value": {
        "@@assign": ["enabled", "disabled"]
      }
    }
  }
}

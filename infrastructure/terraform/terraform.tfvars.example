################################################################################
# ForeTale Application - Terraform Variables
# Copy this file to terraform.tfvars and update values
################################################################################

# AWS Configuration
aws_region   = "us-east-1"
project_name = "foretale"
environment  = "dev"

# VPC Configuration
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

# Subnet Configuration
public_subnet_cidrs   = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs  = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]
database_subnet_cidrs = ["10.0.21.0/24", "10.0.22.0/24", "10.0.23.0/24"]

# NAT Gateway Configuration
enable_nat_gateway = true
single_nat_gateway = true  # Set to false for production (HA)

# Additional Tags
tags = {
  Owner       = "DevOps Team"
  CostCenter  = "Engineering"
  Compliance  = "None"
}

# Phase 2+ Variables (leave empty for Phase 1)
s3_bucket_arns  = []
rds_cluster_arn = ""

# ==================== TERRAFORM =====================
# Terraform working directories (generated by terraform init)
**/.terraform/

# Terraform lock files (optional - can be committed for reproducibility)
# Uncomment the next line if you want to exclude lock files
# .terraform.lock.hcl

# Terraform state files (SENSITIVE - never commit)
*.tfstate
*.tfstate.*
.terraform.tfstate*

# Terraform variable overrides (often contain sensitive values)
*.tfvars
*.tfvars.secrets
*.tfvars.simple
!*.tfvars.example

# Terraform plan files (temporary planning files)
*.tfplan
tfplan*
*.tfplan.json

# Terraform provider cache
.terraform.d/
.terraform.cli/

# Backup files
*.bak
*.backup

# ==================== TEMPORARY/DEBUG FILES =====================
# Terraform apply/plan output logs
apply_output.txt
apply_complete.txt
apply_final.txt
apply_log.txt
apply_new.txt
apply_result.txt
plan.txt
plan_output.txt
plan_check.txt
plan_fixed.txt
plan_new.txt
final_apply.txt


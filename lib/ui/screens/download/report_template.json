{
  "slides": [
    {
      "slide_number": 1,
      "slide_type": "project_details",
      "title": "Project Details",
      "content": {
        "project_name": {
          "data_type": "string",
          "source": "ProjectDetailsModel.getActiveProjectName"
        },
        "project_description": {
          "data_type": "string",
          "source": "ProjectDetailsModel.getProjectDescription"
        },
        "date_of_creation": {
          "data_type": "string",
          "source": "ProjectDetailsModel.getProjectCreatedDate"
        },
        "scope": {
          "data_type": "string",
          "source": "ProjectDetailsModel.getProjectScope"
        },
        "industry": {
          "data_type": "string",
          "source": "ProjectDetailsModel.getIndustryName"
        },
        "company": {
          "data_type": "string",
          "source": "ProjectDetailsModel.getCompanyName"
        },
        "system": {
          "data_type": "string",
          "source": "ProjectDetailsModel.getSystemName"
        }
      }
    },
    {
      "slide_number": 2,
      "slide_type": "test_overview",
      "title": "Test Overview",
      "content": {
        "test_name": {
          "data_type": "string",
          "source": "_selectedTest.testName"
        },
        "test_code": {
          "data_type": "string",
          "source": "_selectedTest.testCode"
        },
        "criticality": {
          "data_type": "string",
          "source": "_selectedTest.testCriticality"
        },
        "category": {
          "data_type": "string",
          "source": "_selectedTest.testCategory"
        },
        "module": {
          "data_type": "string",
          "source": "_selectedTest.module"
        },
        "description": {
          "data_type": "string",
          "source": "_selectedTest.testDescription"
        },
        "potential_risks": {
          "data_type": "list",
          "source": "_selectedTest.identifiedRisks"
        },
        "recommendations": {
          "data_type": "list",
          "source": "_selectedTest.identifiedRecommendations"
        }
      }
    },
    {
      "slide_number": 3,
      "slide_type": "test_results",
      "title": "Test Results",
      "content": {
        "test_result": {
          "data_type": "string",
          "source": "_buildResultSummary(_selectedTest)",
          "logic": "flaggedTransactionsCount > 0 ? '${flaggedTransactionsCount} findings.' : 'Test completed successfully.'"
        },
        "potential_impact": {
          "data_type": "list",
          "source": "_selectedTest.configImpactStatementResultSummary"
        },
        "feedback_summary": {
          "data_type": "list",
          "source": "_selectedTest.feedbackSummary"
        }
      }
    },
    {
      "slide_number": 4,
      "slide_type": "risks_and_recommendations",
      "title": "Identified Risks and Recommendations",
      "content": {
        "identified_risks": {
          "data_type": "list",
          "source": "executionStatsModel.riskTopicList.where((topic) => topic.testId == _selectedTest.testId).toList()"
        },
        "risk_recommendations": {
          "data_type": "list",
          "source": "executionStatsModel.riskRecommendationList.where((rec) => rec.testId == _selectedTest.testId).toList()"
        }
      }
    }
  ]
}
